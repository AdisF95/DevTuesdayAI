@page "/"
@using MediatR
@using WorldCuppy.Features.Matches
@inject ISender Sender

<PageTitle>WorldCuppy 2026</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Match Schedule</MudText>

@if (_today is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    <MatchDaySection Label="Today" Date="_date" Matches="_today" />
    @* _tomorrow! is safe: both lists are set together in OnInitializedAsync; neither can be null here *@
    <MatchDaySection Label="Tomorrow" Date="_date.AddDays(1)" Matches="_tomorrow!" />
}

@code {
    private DateOnly _date;
    private List<MatchResponse>? _today;
    private List<MatchResponse>? _tomorrow;

    /// <summary>Fetches today's and tomorrow's matches (UTC) on page load.</summary>
    protected override async Task OnInitializedAsync()
    {
        _date = DateOnly.FromDateTime(DateTime.UtcNow);
        _today    = await Sender.Send(new GetMatchesByGameDayQuery(_date));
        _tomorrow = await Sender.Send(new GetMatchesByGameDayQuery(_date.AddDays(1)));
    }
}
